{
  "version": 2,
  "installCommand": "npm install && npm --prefix frontend install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/router?path=$1"
    },
    {
      "source": "/room/(.*)",
      "destination": "/index.html"
    }
  ]
}
